# Redis
REDIS_PASSWORD=changeme-redis-password

# PostgreSQL
POSTGRES_PASSWORD=changeme-postgres-password
DATABASE_URL=postgresql://laddr:changeme-postgres-password@postgres:5432/laddr

# Redis URL
REDIS_URL=redis://:changeme-redis-password@redis:6379

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme-minio-password
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme-minio-password
STORAGE_BUCKET=laddr

# API
API_PORT=8000
API_HOST=0.0.0.0

# LLM API Keys (for cloud workers)
VENICE_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# Optional
LADDR_API_KEY=changeme-api-key
